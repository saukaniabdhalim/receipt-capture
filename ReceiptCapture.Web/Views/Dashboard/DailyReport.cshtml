@model List<ReceiptCapture.Data.Models.Receipt>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daily Report</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .stat-card { border-radius: 16px; padding: 24px; color: white; box-shadow: 0 8px 24px rgba(0,0,0,0.1); }
        .category-badge { padding: 4px 12px; border-radius: 20px; color: white; font-size: 0.8em; font-weight: 500; }
        .card { border: none; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.07); }
    </style>
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Index", "Dashboard", new { userId = ViewBag.UserId })">🧾 Receipt Capture</a>
            <span class="navbar-text text-white">@ViewBag.UserName</span>
        </div>
    </nav>

    <div class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="fw-bold mb-0">📅 Daily Report — @((DateTime)ViewBag.Date).ToString("dd MMMM yyyy")</h4>
            <a href="@Url.Action("Index", "Dashboard", new { userId = ViewBag.UserId })" class="btn btn-outline-secondary btn-sm">← Back</a>
        </div>

        @{
            var currentDate = (DateTime)ViewBag.Date;
            var prev = currentDate.AddDays(-1);
            var next = currentDate.AddDays(1);
        }
        <div class="d-flex gap-2 mb-4">
            <a href="@Url.Action("DailyReport", "Dashboard", new { userId = ViewBag.UserId, date = prev.ToString("yyyy-MM-dd") })"
               class="btn btn-outline-primary btn-sm">← @prev.ToString("dd MMM")</a>
            @if (next.Date <= DateTime.UtcNow.Date)
            {
                <a href="@Url.Action("DailyReport", "Dashboard", new { userId = ViewBag.UserId, date = next.ToString("yyyy-MM-dd") })"
                   class="btn btn-outline-primary btn-sm">@next.ToString("dd MMM") →</a>
            }
        </div>

        <div class="row g-4 mb-4">
            <div class="col-md-6">
                <div class="stat-card" style="background: linear-gradient(135deg,#667eea,#764ba2)">
                    <h6 class="mb-1 opacity-75">Total Spent</h6>
                    <h3 class="mb-0">MYR @((decimal)ViewBag.Total).ToString("N2")</h3>
                </div>
            </div>
            <div class="col-md-6">
                <div class="stat-card" style="background: linear-gradient(135deg,#11998e,#38ef7d)">
                    <h6 class="mb-1 opacity-75">Receipts</h6>
                    <h3 class="mb-0">@Model.Count</h3>
                </div>
            </div>
        </div>

        <div class="mb-4">
            <form method="get" class="d-flex gap-2 align-items-center">
                <input type="hidden" name="userId" value="@ViewBag.UserId" />
                <input type="date" name="date" value="@currentDate.ToString("yyyy-MM-dd")" class="form-control form-control-sm w-auto" />
                <button type="submit" class="btn btn-primary btn-sm">Go</button>
            </form>
        </div>

        <div class="card">
            <div class="card-header bg-white border-0 py-3">
                <h6 class="fw-bold mb-0">Transactions</h6>
            </div>
            <div class="card-body p-0">
                @if (!Model.Any())
                {
                    <p class="text-muted text-center py-5">No receipts for this day.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Image</th>
                                    <th>Merchant</th>
                                    <th>Amount</th>
                                    <th class="pe-4">Category</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in Model)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            @if (!string.IsNullOrEmpty(r.ImageUrl))
                                            {
                                                <img src="@r.ImageUrl" style="max-height:60px;border-radius:8px;object-fit:cover" loading="lazy" />
                                            }
                                        </td>
                                        <td class="fw-medium">@(r.MerchantName ?? "Unknown")</td>
                                        <td class="fw-bold text-primary">MYR @r.TotalAmount.ToString("N2")</td>
                                        <td class="pe-4">
                                            @if (r.Category != null)
                                            {
                                                <span class="category-badge" style="background-color:@r.Category.ColorCode">@r.Category.Name</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</body>
</html>
