@model List<ReceiptCapture.Data.Models.Receipt>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Monthly Report</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <style>
        .stat-card { border-radius: 16px; padding: 24px; color: white; box-shadow: 0 8px 24px rgba(0,0,0,0.1); }
        .category-badge { padding: 4px 12px; border-radius: 20px; color: white; font-size: 0.8em; font-weight: 500; }
        .card { border: none; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.07); }
    </style>
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Index", "Dashboard", new { userId = ViewBag.UserId })">🧾 Receipt Capture</a>
            <span class="navbar-text text-white">@ViewBag.UserName</span>
        </div>
    </nav>

    <div class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="fw-bold mb-0">📊 Monthly Report — @ViewBag.MonthName</h4>
            <a href="@Url.Action("Index", "Dashboard", new { userId = ViewBag.UserId })" class="btn btn-outline-secondary btn-sm">← Back</a>
        </div>

        @{
            var prev = new DateTime((int)ViewBag.Year, (int)ViewBag.Month, 1).AddMonths(-1);
            var next = new DateTime((int)ViewBag.Year, (int)ViewBag.Month, 1).AddMonths(1);
        }
        <div class="d-flex gap-2 mb-4">
            <a href="@Url.Action("MonthlyReport", "Dashboard", new { userId = ViewBag.UserId, year = prev.Year, month = prev.Month })"
               class="btn btn-outline-primary btn-sm">← @prev.ToString("MMM yyyy")</a>
            @if (next <= DateTime.UtcNow)
            {
                <a href="@Url.Action("MonthlyReport", "Dashboard", new { userId = ViewBag.UserId, year = next.Year, month = next.Month })"
                   class="btn btn-outline-primary btn-sm">@next.ToString("MMM yyyy") →</a>
            }
        </div>

        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div class="stat-card" style="background: linear-gradient(135deg,#667eea,#764ba2)">
                    <h6 class="mb-1 opacity-75">Total Spent</h6>
                    <h3 class="mb-0">MYR @(((decimal)ViewBag.Total).ToString("N2"))</h3>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card" style="background: linear-gradient(135deg,#11998e,#38ef7d)">
                    <h6 class="mb-1 opacity-75">Receipts</h6>
                    <h3 class="mb-0">@Model.Count</h3>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card" style="background: linear-gradient(135deg,#4facfe,#00f2fe)">
                    <h6 class="mb-1 opacity-75">Average per Receipt</h6>
                    <h3 class="mb-0">MYR @((Model.Count > 0 ? ((decimal)ViewBag.Total / Model.Count) : 0m).ToString("N2"))</h3>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-5">
                <div class="card h-100">
                    <div class="card-header bg-white border-0 py-3">
                        <h6 class="fw-bold mb-0">By Category</h6>
                    </div>
                    <div class="card-body">
                        <canvas id="chart" height="260"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-lg-7">
                <div class="card h-100">
                    <div class="card-header bg-white border-0 py-3">
                        <h6 class="fw-bold mb-0">Transactions</h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">Date</th>
                                        <th>Merchant</th>
                                        <th>Amount</th>
                                        <th class="pe-4">Category</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var r in Model)
                                    {
                                        <tr>
                                            <td class="ps-4 text-muted small">@(r.ReceiptDate?.ToString("dd MMM") ?? "-")</td>
                                            <td class="fw-medium">@(r.MerchantName ?? "Unknown")</td>
                                            <td class="fw-bold text-primary">MYR @r.TotalAmount.ToString("N2")</td>
                                            <td class="pe-4">
                                                @if (r.Category != null)
                                                {
                                                    <span class="category-badge" style="background-color:@r.Category.ColorCode">@r.Category.Name</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const breakdown = @Html.Raw(ViewBag.CategoryBreakdownJson ?? "[]");
        new Chart(document.getElementById('chart').getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: breakdown.map(c => c.Name),
                datasets: [{ data: breakdown.map(c => c.Amount), backgroundColor: breakdown.map(c => c.Color), borderWidth: 0 }]
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } }, cutout: '60%' }
        });
    </script>
</body>
</html>
